rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Sections: public read, only authenticated admin can write
    match /sections/{sectionId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Items: public read, only authenticated admin can write
    match /items/{itemId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

  }
}
